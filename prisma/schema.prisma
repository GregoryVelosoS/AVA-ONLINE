generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_TEXT
  LONG_TEXT
  FILE_UPLOAD
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VisualSupportType {
  NONE
  ASSET
  CODE
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum AttemptStatus {
  STARTED
  IN_PROGRESS
  SUBMITTED
  EXPIRED
  CANCELED
}

enum CorrectionStatus {
  PENDING
  REVIEWED
  RETURNED
}

enum IssueReportType {
  SUGGESTION
  BUG
  QUESTION
}

enum IssueReportStatus {
  NEW
  IN_REVIEW
  RESOLVED
  ARCHIVED
}

enum FeedbackQuestionKey {
  GENERAL_DIFFICULTY
  DIFFICULT_CONTENTS
  COMMON_DIFFICULTY_TYPE
  SELF_PERFORMANCE
  EXPLANATION_CLARITY
  CLASS_PACE
  EXERCISE_USEFULNESS
  SOLO_CONFIDENCE
  HELPFUL_CLASS_FORMATS
  NEEDS_REVIEW
  TOOL_DIFFICULTIES
  FINAL_COMMENT
}

enum FeedbackAnswerType {
  SINGLE_CHOICE
  MULTI_SELECT
  LINEAR_SCALE
  OPEN_TEXT
}

model AdminUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdQuestions Question[]
  createdExams     Exam[]
  corrections      ManualCorrection[]
  issueReports     IssueReport[]
  reportShares     ReportShareLink[]
}

model Discipline {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classGroups ClassGroup[]
  questions   Question[]
  exams       Exam[]
}

model ClassGroup {
  id           String      @id @default(uuid())
  code         String      @unique
  name         String
  disciplineId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  discipline Discipline? @relation(fields: [disciplineId], references: [id])
  exams      Exam[]
}

model Tag {
  id        String   @id @default(uuid())
  label     String   @unique
  color     String?
  createdAt DateTime @default(now())

  questions QuestionTag[]
}

model Question {
  id                String         @id @default(uuid())
  code              String         @unique
  type              QuestionType
  title             String?
  disciplineId      String
  subject           String
  topic             String?
  difficulty        Difficulty
  context           String?
  statement         String
  visualSupportType VisualSupportType @default(NONE)
  supportCode       String?
  expectedFeedback  String?
  answerExplanation String?
  studyTopics       String?
  studyLinks        String?
  referencePlaylist String?
  complementaryNotes String?
  supportImagePath  String?
  supportImageName  String?
  supportImageMime  String?
  supportFilePath   String?
  supportFileName   String?
  supportFileMime   String?
  defaultWeight     Decimal        @default(1)
  status            QuestionStatus @default(DRAFT)
  createdBy         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  archivedAt        DateTime?

  discipline Discipline    @relation(fields: [disciplineId], references: [id])
  author     AdminUser     @relation(fields: [createdBy], references: [id])
  options    QuestionOption[]
  tags       QuestionTag[]
  exams      ExamQuestion[]
  answers    Answer[]
}

model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  label      String
  content    String
  isCorrect  Boolean
  position   Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]
}

model QuestionTag {
  questionId String
  tagId      String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

model Exam {
  id                    String     @id @default(uuid())
  title                 String
  publicCode            String     @unique
  description           String?
  disciplineId          String
  targetClassGroupId    String?
  instructions          String
  startAt               DateTime
  endAt                 DateTime
  timeLimitMinutes      Int?
  status                ExamStatus @default(DRAFT)
  showScoreAfterSubmit  Boolean    @default(false)
  maxAttempts           Int        @default(1)
  randomizeQuestions    Boolean    @default(false)
  randomizeOptions      Boolean    @default(false)
  createdBy             String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  discipline Discipline        @relation(fields: [disciplineId], references: [id])
  classGroup ClassGroup?       @relation(fields: [targetClassGroupId], references: [id])
  author     AdminUser         @relation(fields: [createdBy], references: [id])
  sections   ExamSection[]
  questions  ExamQuestion[]
  publicLinks PublicExamLink[]
  attempts    StudentAttempt[]
  reportShares ReportShareLink[]
  issueReports IssueReport[]
}

model ExamSection {
  id          String @id @default(uuid())
  examId      String
  title       String
  description String?
  position    Int

  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions ExamQuestion[]
}

model ExamQuestion {
  id           String   @id @default(uuid())
  examId        String
  questionId    String
  sectionId     String?
  position      Int
  customWeight  Decimal?
  isRequired    Boolean  @default(true)

  exam     Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])
  section  ExamSection? @relation(fields: [sectionId], references: [id])

  @@unique([examId, position])
}

model PublicExamLink {
  id        String   @id @default(uuid())
  examId    String
  slug      String   @unique
  isActive  Boolean  @default(true)
  validFrom DateTime?
  validUntil DateTime?
  maxUses   Int?
  usedCount Int      @default(0)
  closedAt  DateTime?
  createdAt DateTime @default(now())

  exam     Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  attempts StudentAttempt[]
}

model StudentAttempt {
  id              String        @id @default(uuid())
  examId          String
  publicLinkId    String
  attemptNumber   Int
  status          AttemptStatus @default(STARTED)
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  autoScore       Decimal       @default(0)
  manualScore     Decimal       @default(0)
  finalScore      Decimal       @default(0)
  durationSeconds Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exam       Exam                    @relation(fields: [examId], references: [id], onDelete: Cascade)
  publicLink PublicExamLink          @relation(fields: [publicLinkId], references: [id])
  profile    StudentProfileSnapshot?
  answers    Answer[]
  feedback   FeedbackFormResponse?
  issueReports IssueReport[]

  @@index([examId, status])
}

model StudentProfileSnapshot {
  id                 String @id @default(uuid())
  attemptId          String @unique
  studentName        String
  classGroupName     String
  disciplineInformed String

  attempt StudentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model Answer {
  id               String  @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  shortTextAnswer  String?
  longTextAnswer   String?
  isCorrect        Boolean?
  autoScore        Decimal @default(0)
  manualScore      Decimal @default(0)
  finalScore       Decimal @default(0)
  confidenceLevel  Int
  answeredAt       DateTime @default(now())

  attempt      StudentAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question          @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id])
  attachments  AnswerAttachment[]
  correction   ManualCorrection?

  @@unique([attemptId, questionId])
}

model AnswerAttachment {
  id              String   @id @default(uuid())
  answerId        String
  storageProvider String
  filePath        String
  originalName    String
  mimeType        String
  sizeBytes       BigInt
  createdAt       DateTime @default(now())

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
}

model ManualCorrection {
  id         String           @id @default(uuid())
  answerId   String           @unique
  reviewerId String
  score      Decimal
  comment    String?
  status     CorrectionStatus @default(PENDING)
  reviewedAt DateTime?

  answer   Answer    @relation(fields: [answerId], references: [id], onDelete: Cascade)
  reviewer AdminUser @relation(fields: [reviewerId], references: [id])
}

model FeedbackFormResponse {
  id                    String  @id @default(uuid())
  attemptId             String  @unique
  clarityScore          Int
  difficultyScore       Int
  timeAdequacyScore     Int
  contentAlignmentScore Int
  selfAssessmentScore   Int
  confusingQuestionFlag Boolean
  openComment           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  attempt StudentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  answers FeedbackAnswer[]
}

model FeedbackAnswer {
  id              String             @id @default(uuid())
  feedbackId      String
  questionKey     FeedbackQuestionKey
  answerType      FeedbackAnswerType
  valueText       String?
  valueScale      Int?
  selectedOptions String?
  createdAt       DateTime           @default(now())

  feedback FeedbackFormResponse @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, questionKey])
}

model ReportShareLink {
  id         String   @id @default(uuid())
  examId      String
  token      String   @unique
  label      String?
  isActive   Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exam   Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  author AdminUser @relation(fields: [createdBy], references: [id])
}

model IssueReport {
  id               String            @id @default(uuid())
  type             IssueReportType
  status           IssueReportStatus @default(NEW)
  title            String
  description      String
  sourcePath       String
  sourceUrl        String?
  contextLabel     String?
  screenshotPath   String?
  screenshotName   String?
  screenshotMime   String?
  adminUserId      String?
  examId           String?
  attemptId        String?
  internalNotes    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  adminUser AdminUser?      @relation(fields: [adminUserId], references: [id])
  exam      Exam?           @relation(fields: [examId], references: [id])
  attempt   StudentAttempt? @relation(fields: [attemptId], references: [id])
}
